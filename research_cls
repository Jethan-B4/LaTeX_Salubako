% research.cls - Custom Research Class
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{research}[2025/01/01 Custom Research Class]

% Base class
\LoadClass[12pt]{report}



% Page size
\usepackage{geometry}
\geometry{
  paperwidth=8.5in,
  paperheight=11in,
  left=1.5in,
  right=1in,
  top=1in,
  bottom=1in
}

% Page numbering
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[R]{\thepage}

% Avoid widow and orphan (no hanging pages)
\clubpenalty=10000
\widowpenalty=10000
\displaywidowpenalty=10000

% Chapter formatting — matches TestX template:
%   numbered, left-aligned, normal (not bold), Large size
\usepackage{titlesec}
\titleformat{\chapter}[hang]{\Large\normalfont}{\thechapter}{1em}{}

% TOC formatting
\usepackage{tocloft}
\setlength{\cftbeforechapskip}{1em}

% References
\usepackage[numbers,sort&compress]{natbib}

% Title Page Command
\newcommand{\researchtitlepage}{%
  \thispagestyle{empty}
  \begin{center}
    \vspace*{2in}
    {\Huge\bfseries \thetitle \par}
    \vspace{1in}
    {Submitted to \\ \thesubmission \par}
    \vfill
    {\large \theauthor \\ \theyear}
  \end{center}
  \clearpage
}

% User Data
\newcommand{\submission}[1]{\def\thesubmission{#1}}
\newcommand{\researchyear}[1]{\def\theyear{#1}}

% Paragraph formatting
\setlength{\parskip}{6pt}
\setlength{\parindent}{0.5in}

% --- Precise Spacing Control ---

% Section/subsection formatting — matches TestX template (normal weight, left-aligned)
\titleformat{\section}[hang]{\normalsize\normalfont}{\thesection}{1em}{}
\titleformat{\subsection}[hang]{\normalsize\normalfont}{\thesubsection}{1em}{}
\titleformat{\subsubsection}[hang]{\normalsize\normalfont}{\thesubsubsection}{1em}{}

% \titlespacing*{command}{left}{before-sep}{after-sep}

% 1. Chapter Spacing
\titlespacing*{\chapter}{0pt}{-30pt}{6pt}

% 2. Section Spacing
\titlespacing*{\section}{0pt}{6pt}{3pt}

% 3. Subsection Spacing
\titlespacing*{\subsection}{0pt}{4pt}{2pt}





% Table of Contents Reduce Spaces
\usepackage{tocloft}
% Space before "Contents" title
\setlength{\cftbeforetoctitleskip}{0pt}
% Space after "Contents" title
\setlength{\cftaftertoctitleskip}{10pt}



% List of Figures Reduce Spaces
\usepackage{tocloft}
% Space before "List of Figures" title
\setlength{\cftbeforeloftitleskip}{5pt}
% Space after "List of Figures" title
\setlength{\cftafterloftitleskip}{5pt}
\setlength{\cftbeforelottitleskip}{5pt}
\setlength{\cftafterlottitleskip}{5pt}
