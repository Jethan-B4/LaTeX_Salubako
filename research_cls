% research.cls - Custom Research Class
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{research}[2025/01/01 Custom Research Class]

% Base class
\LoadClass[12pt]{report}



% Page size
\usepackage{geometry}
\geometry{
  paperwidth=8.5in,
  paperheight=11in,
  left=1.5in,
  right=1in,
  top=1in,
  bottom=1in
}

% Page numbering
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[R]{\thepage}
\setlength{\headheight}{14.5pt}

% Avoid widow and orphan (no hanging pages)
\clubpenalty=10000
\widowpenalty=10000
\displaywidowpenalty=10000

% Chapter formatting — bold, left-aligned, Large size (matches sample PDF)
\usepackage{titlesec}
\titleformat{\chapter}[hang]{\Large\bfseries}{\thechapter}{1em}{}

% TOC formatting — match sample PDF
\usepackage{tocloft}
\setlength{\cftbeforechapskip}{1em}

% TOC title styling — \Large\bfseries to match List of Figures/Tables title
\renewcommand{\cfttoctitlefont}{\Large\bfseries}
\renewcommand{\cftaftertoctitle}{}

% Chapter entries: bold, normal size, with dot leaders
\renewcommand{\cftchapfont}{\normalsize\bfseries}
\renewcommand{\cftchappagefont}{\normalsize\bfseries}
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}

% Section entries: normal weight, normal size
\renewcommand{\cftsecfont}{\normalsize}
\renewcommand{\cftsecpagefont}{\normalsize}
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}

% Subsection entries: normal weight, normal size
\renewcommand{\cftsubsecfont}{\normalsize}
\renewcommand{\cftsubsecpagefont}{\normalsize}
\renewcommand{\cftsubsecleader}{\cftdotfill{\cftdotsep}}

% References
\usepackage[round,authoryear]{natbib}

% Caption styling — label bold, title text normal weight (removes redundant bold)
\usepackage[labelfont=bf,textfont=normalfont,labelsep=period]{caption}

% Title Page Command
\newcommand{\researchtitlepage}{%
  \thispagestyle{empty}
  \begin{center}
    \vspace*{2in}
    {\Huge\bfseries \thetitle \par}
    \vspace{1in}
    {Submitted to \\ \thesubmission \par}
    \vfill
    {\large \theauthor \\ \theyear}
  \end{center}
  \clearpage
}

% User Data
\newcommand{\submission}[1]{\def\thesubmission{#1}}
\newcommand{\researchyear}[1]{\def\theyear{#1}}

% Paragraph formatting
\setlength{\parskip}{6pt}
\setlength{\parindent}{0.5in}

% --- Precise Spacing Control ---

% Section/subsection formatting — bold, left-aligned (matches sample PDF)
\titleformat{\section}[hang]{\normalsize\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}[hang]{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}[hang]{\normalsize\bfseries}{\thesubsubsection}{1em}{}

% \titlespacing*{command}{left}{before-sep}{after-sep}

% 1. Chapter Spacing
\titlespacing*{\chapter}{0pt}{-30pt}{6pt}

% 2. Section Spacing
\titlespacing*{\section}{0pt}{6pt}{3pt}

% 3. Subsection Spacing
\titlespacing*{\subsection}{0pt}{4pt}{2pt}





% Table of Contents spacing
\setlength{\cftbeforetoctitleskip}{0pt}
\setlength{\cftaftertoctitleskip}{10pt}

% List of Figures / List of Tables spacing
\setlength{\cftbeforeloftitleskip}{5pt}
\setlength{\cftafterloftitleskip}{5pt}
\setlength{\cftbeforelottitleskip}{5pt}
\setlength{\cftafterlottitleskip}{5pt}
