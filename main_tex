\begin{center}
  {\bfseries APPENDIX F}\\[1em]
  {\bfseries System Algorithms}
\end{center}

\vspace{1em}
{\small

\noindent\textbf{Algorithm 1: Overall Game Flow}\par
\noindent\rule{\textwidth}{0.4pt}
\noindent\textbf{Input:} \textit{playerInput, saveData, sceneTriggers, questData}\par
\noindent\textbf{Output:} \textit{gameState, loadedScene, updatedQuestProgress}\par
\noindent\rule{\textwidth}{0.4pt}
\begin{enumerate}[leftmargin=0.75cm, topsep=2pt, itemsep=0pt, parsep=0pt]
  \item \textbf{INITIALIZE} gameState, save profile, questData, and current scene
  \item \textbf{DISPLAY} main menu and available save slots
  \item \textbf{IF} player selects New Game \textbf{THEN} create initial saveData and load prologue scene
  \item \textbf{ELSE IF} player selects Continue \textbf{THEN} load saved scene and quest progress
  \item \textbf{WHILE} game is running \textbf{DO}
  \item \hspace{0.4cm}\textbf{PROCESS} player input, movement, nearby interactables, dialogue, quests, minigames, and UI updates
  \item \hspace{0.4cm}\textbf{IF} scene trigger is entered and confirmed \textbf{THEN} load target scene
  \item \hspace{0.4cm}\textbf{IF} quest objective is completed \textbf{THEN} update quest progress and unlock next marker, item, dialogue, trigger, or scene
  \item \hspace{0.4cm}\textbf{IF} minigame starts \textbf{THEN} disable normal movement, run minigame rules, show result, and return to story scene
  \item \textbf{END WHILE}
  \item \textbf{RETURN} gameState, loadedScene, and updatedQuestProgress
\end{enumerate}

\vspace{0.75cm}
\noindent\textbf{Algorithm 2: Player Movement and Interaction System}\par
\noindent\rule{\textwidth}{0.4pt}
\noindent\textbf{Input:} \textit{movementInput, interactionInput, playerPosition}\par
\noindent\textbf{Output:} \textit{updatedPlayerPosition, interactionState}\par
\noindent\rule{\textwidth}{0.4pt}
\begin{enumerate}[leftmargin=0.75cm, topsep=2pt, itemsep=0pt, parsep=0pt]
  \item \textbf{INITIALIZE} Rigidbody2D, Animator, facingDirection, and canMove $\leftarrow$ true
  \item \textbf{EVERY FRAME} read movementInput and interactionInput
  \item \textbf{IF} canMove is false \textbf{THEN} stop velocity, disable walk animation, and skip movement update
  \item \textbf{NORMALIZE} movement direction and compute velocity using moveSpeed
  \item \textbf{UPDATE} Rigidbody2D velocity and animator direction values
  \item \textbf{IF} horizontal direction changes \textbf{THEN} flip player sprite on the X axis
  \item \textbf{IF} interactionInput is pressed and current interactable exists \textbf{THEN} validate conditions and run interaction event
  \item \textbf{RETURN} updatedPlayerPosition and interactionState
\end{enumerate}

\vspace{0.75cm}
\noindent\textbf{Algorithm 3: Dialogue System}\par
\noindent\rule{\textwidth}{0.4pt}
\noindent\textbf{Input:} \textit{NPCData, dialogueLines, playerInteraction}\par
\noindent\textbf{Output:} \textit{dialogueDisplay, dialogueProgress}\par
\noindent\rule{\textwidth}{0.4pt}
\begin{enumerate}[leftmargin=0.75cm, topsep=2pt, itemsep=0pt, parsep=0pt]
  \item \textbf{CHECK} NPCData when playerInteraction occurs
  \item \textbf{IF} NPC has no dialogue data \textbf{THEN} stop interaction
  \item \textbf{IF} dialogue is already active \textbf{THEN} advance to the next dialogue line
  \item \textbf{ELSE} set dialogueActive $\leftarrow$ true, dialogueIndex $\leftarrow$ 0, and disable player movement
  \item \textbf{DISPLAY} dialogue panel and current dialogue line
  \item \textbf{FOR EACH} character in current dialogue line \textbf{DO} append character to dialogue text using typing delay
  \item \textbf{IF} more dialogue lines exist \textbf{THEN} display next line
  \item \textbf{ELSE} hide dialogue panel and enable player movement
  \item \textbf{RETURN} dialogueDisplay and dialogueProgress
\end{enumerate}

\vspace{0.75cm}
\noindent\textbf{Algorithm 4: Quest System}\par
\noindent\rule{\textwidth}{0.4pt}
\noindent\textbf{Input:} \textit{questID, playerAction, questProgress}\par
\noindent\textbf{Output:} \textit{updatedQuest, rewardStatus}\par
\noindent\rule{\textwidth}{0.4pt}
\begin{enumerate}[leftmargin=0.75cm, topsep=2pt, itemsep=0pt, parsep=0pt]
  \item \textbf{LOAD} quest save data and initialize active quest list
  \item \textbf{WHEN} player interacts with quest NPC, check active quest state
  \item \textbf{IF} quest objective is incomplete \textbf{THEN} display quest dialogue and advance quest progress
  \item \textbf{IF} quest reaches final stage \textbf{THEN} mark quest completed, give reward, and unlock next quest or area
  \item \textbf{SAVE} updated quest data
  \item \textbf{RETURN} updatedQuest and rewardStatus
\end{enumerate}

\vspace{0.75cm}
\noindent\textbf{Algorithm 5: Scene Transition System}\par
\noindent\rule{\textwidth}{0.4pt}
\noindent\textbf{Input:} \textit{playerPosition, transitionTrigger, targetScene}\par
\noindent\textbf{Output:} \textit{loadedScene, playerSpawnPosition}\par
\noindent\rule{\textwidth}{0.4pt}
\begin{enumerate}[leftmargin=0.75cm, topsep=2pt, itemsep=0pt, parsep=0pt]
  \item \textbf{DETECT} player collision with transitionTrigger
  \item \textbf{IF} collision is detected \textbf{THEN} display transition prompt
  \item \textbf{IF} player confirms transition \textbf{THEN} save current data, start fade transition, load targetScene, and set spawn position
  \item \textbf{RETURN} loadedScene and playerSpawnPosition
\end{enumerate}

\vspace{0.75cm}
\noindent\textbf{Algorithm 6: Collection Minigame System}\par
\noindent\rule{\textwidth}{0.4pt}
\noindent\textbf{Input:} \textit{collectibleObjects, timerValue, playerInteraction}\par
\noindent\textbf{Output:} \textit{gameResult, collectedItemCount}\par
\noindent\rule{\textwidth}{0.4pt}
\begin{enumerate}[leftmargin=0.75cm, topsep=2pt, itemsep=0pt, parsep=0pt]
  \item \textbf{INITIALIZE} collectedItemCount $\leftarrow$ 0 and display minigame instruction panel
  \item \textbf{START} countdown timer and enable player movement
  \item \textbf{WHILE} minigame is active \textbf{DO} decrease timerValue and update timer display
  \item \textbf{IF} player collects an item \textbf{THEN} increase collectedItemCount and update item counter UI
  \item \textbf{IF} all collectibleObjects are collected \textbf{THEN} end game with WIN result
  \item \textbf{IF} timerValue reaches zero \textbf{THEN} end game with LOSE result
  \item \textbf{RETURN} gameResult and collectedItemCount
\end{enumerate}
}

